{
  "name": "tahmisci-site",
  "version": "1.0.0",
  "private": true,
  "description": "Tahmisci website, admin, recipe, QR menu and API workspace",
  "workspaces": [
    "apps/api"
  ],
  "scripts": {
    "dev:local": "node ./apps/api/scripts/local-dev.js",
    "local:reset": "node ./apps/api/scripts/local-reset.js",
    "test:local": "node ./apps/api/scripts/local-smoke-test.js",
    "check": "npm --workspace tahmisci-menu-backend run check",
    "check:assets": "npm --workspace tahmisci-menu-backend run check:assets",
    "check:paths": "npm --workspace tahmisci-menu-backend run check:assets",
    "check:duplicates": "node ./scripts/check-duplicates.js",
    "test": "npm --workspace tahmisci-menu-backend test"
  },
  "engines": {
    "node": ">=18"
  }
}
